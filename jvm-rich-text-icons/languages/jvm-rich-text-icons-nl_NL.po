msgstr "Icoonset"

#: src/settings.php:368
msgid "Font Awesome 4.7"
msgstr "Font Awesome 4.7"

#: src/settings.php:369
msgid "Font Awesome Free 5.15.4"
msgstr "Font Awesome Free 5.15.4"

#: src/settings.php:370
msgid "Font Awesome Free 6.7.2"
msgstr "Font Awesome Free 6.7.2"

#: src/settings.php:402
msgid "Render technology"
msgstr "Rendertechnologie"

#: src/settings.php:407
msgid "Inline SVG"
msgstr "Inline SVG"

#: src/settings.php:410
msgid "HTML + CSS"
msgstr "HTML + CSS"

#: src/settings.php:412
msgid "HTML + CSS ::before pseudo-element"
msgstr "HTML + CSS ::before pseudo-element"

#: src/settings.php:415
msgid "HTML + CSS ::after pseudo-element"
msgstr "HTML + CSS ::after pseudo-element"

#: src/settings.php:478
msgid "Normalize colors"
msgstr "Kleuren normaliseren"

#: src/settings.php:479
msgid "Replace hardcoded fill and stroke colors with currentColor so icons automatically inherit the surrounding text color. White is excluded."
msgstr "Vervang hardgecodeerde vul- en lijnkleuren door currentColor zodat iconen automatisch de omringende tekstkleur erven. Wit is uitgesloten."

#: src/settings.php:482
msgid "Normalize viewBox"
msgstr "ViewBox normaliseren"

#: src/settings.php:483
msgid "Derive a viewBox from width/height attributes when missing, then remove explicit width/height so the icon scales freely with CSS."
msgstr "Leid een viewBox af van width/height-attributen als deze ontbreken en verwijder dan expliciete width/height zodat het icoon vrij schaalt met CSS."

#: src/settings.php:486
msgid "Square viewBox"
msgstr "Vierkante viewBox"

#: src/settings.php:487
msgid "Pad non-square viewBoxes to a square canvas by centering the content. Useful when icons need uniform dimensions in a grid."
msgstr "Zet niet-vierkante viewBoxen op een vierkant canvas door de inhoud te centreren. Nuttig wanneer iconen uniforme afmetingen nodig hebben in een raster."

#: src/settings.php:490
msgid "Remove IDs"
msgstr "ID's verwijderen"

#: src/settings.php:491
msgid "Strip id attributes to prevent DOM collisions when the same icon appears multiple times on a page. IDs on mask elements are always preserved."
msgstr "Strip id-attributen om DOM-botsingen te voorkomen wanneer hetzelfde icoon meerdere keren op een pagina verschijnt. ID's op maskerelementen blijven altijd behouden."

#: src/settings.php:494
msgid "Convert white masks"
msgstr "Witte maskers omzetten"

#: src/settings.php:495
msgid "Auto-detect icons that use white shapes as cutouts and convert them to proper SVG mask elements. This ensures they render correctly with currentColor."
msgstr "Detecteer automatisch iconen die witte vormen gebruiken als uitsnijdingen en converteer ze naar de juiste SVG-maskerelementen. Dit zorgt ervoor dat ze correct worden weergegeven met currentColor."

#: src/init.php:70
msgid "Donate to Support"
msgstr "Doneer om te steunen"

#: src/init.php:94
msgid "Insert icon"
msgstr "Icoon invoegen"

#: src/init.php:306
msgid "Enjoying %1$s? Please consider %2$sleaving a review%3$s — it helps other WordPress users find this plugin."
msgstr "Geniet je van %1$s? Overweeg dan %2$snog een recensie achter te laten%3$s — het helpt andere WordPress-gebruikers om deze plugin te vinden."

#: src/svg-sanitizer.php:139
msgid "SVG input is empty."
msgstr "SVG-invoer is leeg."

#: src/svg-sanitizer.php:146
msgid "Failed to parse SVG."
msgstr "SVG is niet geparseerd."

#: src/svg-sanitizer.php:153
msgid "Root element is not <svg>."
msgstr "Root element is niet <svg>."

#: src/svg-sanitizer.php:190
msgid "SVG file not found or not readable."
msgstr "SVG-bestand niet gevonden of niet leesbaar."

#: src/svg-sanitizer.php:196
msgid "Could not read SVG file."
msgstr "Kan SVG-bestand niet lezen."

#: src/svg-sanitizer.php:417
msgid "Icon contains white shapes that appear to be used as masks. Consider reviewing the SVG manually."
msgstr "Icoon bevat witte vormen die als maskers lijken te worden gebruikt. Overweeg om de SVG handmatig te bekijken."

#: src/svg-sanitizer.php:420
msgid "Icon contains white-filled elements. These have been left as-is — verify the icon renders correctly."
msgstr "Icoon bevat witgevulde elementen. Deze zijn ongewijzigd gelaten - controleer of het icoon correct wordt weergegeven."
